#!/bin/bash

# Pull user defined variables
source "$(dirname "$0")/setup_variables"
source "$(dirname "$0")/gpg-helpers.sh"

REQUESTED_COMMAND="${1:-}"

function validate_setup_variables {
  if [ -z "${PASSPHRASE:-}" ] || [ -z "${REALNAME:-}" ] || [ -z "${EMAIL:-}" ] || [ -z "${KEYPIN:-}" ] || [ -z "${ADMINPIN:-}" ] || [ -z "${RESETCODE:-}" ]
  then
    echo "A required variable is not set. Run './setup-yubikey setup-vars' or edit 'setup_variables' and try again."
    exit 1
  fi

  if [ "${#KEYPIN}" -lt 6 ]
  then
    echo "KEYPIN must be at least 6 characters. Run './setup-yubikey setup-vars' or edit 'setup_variables' and try again."
    exit 1
  fi

  if [ "${#ADMINPIN}" -lt 8 ] || [ "${#RESETCODE}" -lt 8 ]
  then
    echo "ADMINPIN and RESETCODE must each be at least 8 characters. Run './setup-yubikey setup-vars' or edit 'setup_variables' and try again."
    exit 1
  fi
}

case "$REQUESTED_COMMAND" in
  ''|'help'|'-h'|'--help'|'setup-vars')
    ;;
  *)
    validate_setup_variables
    ;;
esac

if [ ! -d ~/.gnupg/ ]
then
  mkdir -p ~/.gnupg/
fi

chmod 700 ~/.gnupg/

## Don't modify below
OS="$(uname -s)"
case "$OS" in
  Linux)
    if [[ -f "/etc/os-release" ]]; then
      grep -q 'NAME="Ubuntu"' /etc/os-release || { echo 'Unsupported Linux distribution. We only support Ubuntu.'; exit 1; }
    else
      echo 'Unsupported Linux distribution. We only support Ubuntu.'
      exit 1
    fi
    ;;
  Darwin)
    ;; # macOS -- supported
  *)
    echo "Unsupported OS: $OS"
    exit 1
    ;;
esac

set -euo pipefail

# Detect user's shell RC file for profile modifications
case "${SHELL:-/bin/bash}" in
  */zsh)  SHELL_RC="$HOME/.zshrc" ;;
  */bash) SHELL_RC="$HOME/.bashrc" ;;
  *)      SHELL_RC="$HOME/.profile" ;;
esac

unset SSH_AUTH_SOCK

function init_ez {
  install
  sleep 1
  generate_master
  cleanup
}

function setup_key_ez {
  reset_yubikey
  sleep 1
  keys_to_card
  sleep 5
  enable_hmac || true
}

function setup_gpg_agent {
  gpg-setup-gpg-agent "$SHELL_RC" "$OS"
}

function setup_gpg_helpers {
  gpg-install-helpers "$(dirname "$0")/gpg-helpers.sh" "$SHELL_RC"
}

function oneshot {
  setup_vars
  init_ez
  setup_key_ez
  setup_gpg_agent
  setup_gpg_helpers
}

function _escape_single_quotes {
  local value="$1"
  printf "%s" "${value//\'/\'\\\'\'}"
}

function _prompt_nonempty_value {
  local prompt="$1"
  local value=""

  while true; do
    read -r -p "$prompt" value
    if [ -n "$value" ]; then
      printf '%s' "$value"
      return 0
    fi
    echo "Value cannot be empty."
  done
}

function _prompt_secret_value {
  local prompt="$1"
  local min_len="$2"
  local value=""
  local confirm=""

  while true; do
    read -r -s -p "$prompt" value
    echo ""
    read -r -s -p "Confirm: " confirm
    echo ""

    if [ -z "$value" ]; then
      echo "Value cannot be empty."
      continue
    fi

    if [ "$value" != "$confirm" ]; then
      echo "Values do not match. Try again."
      continue
    fi

    if [ "$min_len" -gt 0 ] && [ "${#value}" -lt "$min_len" ]; then
      echo "Value must be at least $min_len characters."
      continue
    fi

    printf '%s' "$value"
    return 0
  done
}

function setup_vars {
  local vars_file
  local overwrite_reply
  local has_nondefault_values=0
  local input_realname
  local input_email
  local input_passphrase
  local input_keypin
  local input_adminpin
  local input_resetcode
  local escaped_realname
  local escaped_email
  local escaped_passphrase
  local escaped_keypin
  local escaped_adminpin
  local escaped_resetcode

  vars_file="$(dirname "$0")/setup_variables"

  if [ -n "${PASSPHRASE:-}" ] && [ "$PASSPHRASE" != "asdfASDF1234" ]; then
    has_nondefault_values=1
  fi
  if [ -n "${REALNAME:-}" ] && [ "$REALNAME" != "Valued Employee" ]; then
    has_nondefault_values=1
  fi
  if [ -n "${EMAIL:-}" ] && [ "$EMAIL" != "valued@a.com" ]; then
    has_nondefault_values=1
  fi
  if [ -n "${KEYPIN:-}" ] && [ "$KEYPIN" != "654321" ]; then
    has_nondefault_values=1
  fi
  if [ -n "${ADMINPIN:-}" ] && [ "$ADMINPIN" != "11122211" ]; then
    has_nondefault_values=1
  fi
  if [ -n "${RESETCODE:-}" ] && [ "$RESETCODE" != "87654321" ]; then
    has_nondefault_values=1
  fi

  if [ "$has_nondefault_values" -eq 1 ]; then
    echo "Existing non-default values were detected in setup_variables."
    read -r -p "Continue and overwrite them? [y/N]: " overwrite_reply
    case "$overwrite_reply" in
      [Yy]|[Yy][Ee][Ss])
        ;;
      *)
        echo "setup-vars cancelled."
        return 0
        ;;
    esac
  fi

  input_realname="$(_prompt_nonempty_value 'Enter REALNAME: ')"

  while true; do
    input_email="$(_prompt_nonempty_value 'Enter EMAIL: ')"
    if [[ "$input_email" == *"@"*"."* ]]; then
      break
    fi
    echo "EMAIL must look like user@example.com"
  done

  input_passphrase="$(_prompt_secret_value 'Enter PASSPHRASE: ' 1)"
  input_keypin="$(_prompt_secret_value 'Enter KEYPIN (min 6 chars): ' 6)"
  input_adminpin="$(_prompt_secret_value 'Enter ADMINPIN (min 8 chars): ' 8)"
  input_resetcode="$(_prompt_secret_value 'Enter RESETCODE (min 8 chars): ' 8)"

  escaped_realname="$(_escape_single_quotes "$input_realname")"
  escaped_email="$(_escape_single_quotes "$input_email")"
  escaped_passphrase="$(_escape_single_quotes "$input_passphrase")"
  escaped_keypin="$(_escape_single_quotes "$input_keypin")"
  escaped_adminpin="$(_escape_single_quotes "$input_adminpin")"
  escaped_resetcode="$(_escape_single_quotes "$input_resetcode")"

  cat <<EOF > "$vars_file"
### Edit these variables to your liking ###

# Staff identity
PASSPHRASE='$escaped_passphrase'
REALNAME='$escaped_realname'
EMAIL='$escaped_email'

# Yubikey Parameters
KEYPIN='$escaped_keypin' # Must be at least 6 chars; used often to unlock the yubikey
ADMINPIN='$escaped_adminpin' # Must be at least 8 chars
RESETCODE='$escaped_resetcode' # Must be at least 8 chars

# LUKS Parameters -- Typically, leave these alone
LUKS_SIZE_IN_GB='${LUKS_SIZE_IN_GB:-500}'
LUKS_PATH='${LUKS_PATH:-${HOME}/yubikey_luks}'
EOF

  chmod 600 "$vars_file"
  source "$vars_file"
  echo "setup_variables updated successfully."
}

function help {
  cat <<EOF
Usage: $0 <command>

Commands:
  init               Install required dependencies
  init-ez            Run init + generate-master quick flow
  reset-yubikey      Reset YubiKey applications to defaults
  generate-master    Generate OpenPGP master key material
  setup-key-ez       Run reset-yubikey + keys-to-card + enable-hmac
  keys-to-card       Move generated keys to YubiKey slots
  keys-to-user       Copy key stubs to ~/.gnupg
  enable-hmac        Configure HMAC challenge-response on YubiKey
  setup-gpg-agent    Configure and start gpg-agent with SSH support
  setup-gpg-helpers  Install helper functions into your shell profile
  oneshot            Run setup-vars, init-ez, setup-key-ez, setup-gpg-agent, setup-gpg-helpers
  setup-vars         Interactively update setup_variables
  help               Show this command help
EOF
}

function cleanup {
  killall -9 scdaemon > /dev/null 2>&1 || true
  killall -9 gpg-agent > /dev/null 2>&1 || true
}

function enable_hmac {
  # macOS does not need sudo for ykpersonalize (no udev/plugdev group)
  local SUDO_PREFIX="sudo"
  if [[ "$OS" == "Darwin" ]]; then
    SUDO_PREFIX=""
  fi

  # HMAC challenge-response uses the OTP interface; ensure it is enabled.
  if [[ -n "$SUDO_PREFIX" ]]; then
    $SUDO_PREFIX ykman config usb --enable OTP -f >/dev/null 2>&1 || true
  else
    ykman config usb --enable OTP -f >/dev/null 2>&1 || true
  fi
  sleep 5
  if [[ -f "$(pwd)/hmac_key" ]]; then
    echo "Found existing hmac key, loading in slot 2"
    key="$(cat "${HOME}/hmac_key")"
    $SUDO_PREFIX ykpersonalize -a"${key}" -y -2 -ochal-resp -ochal-hmac -ohmac-lt64 -oserial-api-visible 1>/dev/null
  else
    echo "Generating new hmac key, loading in slot 2"
    $SUDO_PREFIX ykpersonalize -y -2 -ochal-resp -ochal-hmac -ohmac-lt64 -oserial-api-visible 2>&1 | grep 'key: ' | sed 's/key: //g' > "$(pwd)/hmac_key"
  fi
}

function install {
  if [[ "$OS" == "Darwin" ]]; then
    if ! command -v brew &>/dev/null; then
      echo "Homebrew is required on macOS. Install it from https://brew.sh"
      exit 1
    fi
    brew install gnupg pinentry-mac ykpers ykman 2>/dev/null || brew upgrade gnupg pinentry-mac ykpers ykman 2>/dev/null || true
  else
    sudo apt-get -y install gpg gpg-agent scdaemon yubikey-manager yubikey-personalization yubikey-personalization-gui yubikey-luks > /dev/null 2>&1

    cat << EOP | sudo tee /etc/udev/rules.d/99-yubikey.rules
# YubiKey 4 OTP+U2F+CCID
SUBSYSTEMS=="usb", ATTRS{idVendor}=="1050", ATTRS{idProduct}=="0407", GROUP="plugdev"
EOP
    sudo udevadm control --reload-rules && sudo udevadm trigger
  fi
}

function reset_yubikey {
  cleanup
  sleep 1
  ykman piv reset -f
  ykman openpgp reset -f
  ykman oath reset -f
  ykman hsmauth reset -f
  #read -r -p "Unplug your YubiKey, plug it back in (within 5 seconds), then press Enter to continue with FIDO reset... "
  #ykman fido reset -f
  ykman config usb --enable OTP -f
}

function generate_master {
  local overwrite_reply

  GENERATE_MASTER_SKIPPED=0

  if [ -d "gnupg_home" ] || compgen -G "*-keyring.tar.gz" >/dev/null; then
    echo "Detected existing key setup artifacts in this directory."
    echo -n "Overwrite and regenerate master key material? [y/N]: "
    read -r overwrite_reply

    case "$overwrite_reply" in
      [Yy]|[Yy][Ee][Ss])
        ;;
      *)
        echo "Skipping master key generation and keeping existing artifacts."
        GENERATE_MASTER_SKIPPED=1
        return 0
        ;;
    esac
  fi

  rm -fR gnupg_home
  mkdir -p gnupg_home && chmod 700 gnupg_home && cd gnupg_home

  export GNUPGHOME="$(pwd)"
  cleanup
cat << EOF > "$GNUPGHOME/gpg.conf"
default-preference-list SHA512 SHA384 SHA256 SHA224 AES256 AES192 AES CAMELLIA256 CAMELLIA192 CAMELLIA128 TWOFISH
cert-digest-algo SHA512
keyid-format 0xlong
use-agent
lock-never
EOF

  if [[ "$OS" == "Darwin" ]]; then
    PINENTRY_PATH="$(which pinentry-mac 2>/dev/null || echo /opt/homebrew/bin/pinentry-mac)"
  else
    PINENTRY_PATH="/usr/bin/pinentry-gnome3"
  fi

cat << EOF > "$GNUPGHOME/gpg-agent.conf"
enable-ssh-support
default-cache-ttl 600
max-cache-ttl 7200
default-cache-ttl-ssh 600
max-cache-ttl-ssh 7200
pinentry-program ${PINENTRY_PATH}
EOF

#Uppercase E needed gpg < 2.1.17
cat > "$GNUPGHOME/genscript" <<EOF
%echo Generating a basic OpenPGP key
Key-Type: eddsa
Key-Curve: Ed25519
Name-Real: ${REALNAME}
Name-Email: ${EMAIL}
Expire-Date: 0
Passphrase: ${PASSPHRASE}
# Do a commit here, so that we can later print "done" :-)
%commit
%echo done
EOF

gpg --batch --generate-key genscript > /dev/null 2>&1
rm -f genscript
#gpg --list-secret-keys

KEYID=$(gpg --list-options show-only-fpr-mbox --list-secret-keys 2>/dev/null | awk '{print $1;}')

gpg --pinentry-mode=loopback --passphrase "$PASSPHRASE" --armor --export-secret-keys $KEYID > "$GNUPGHOME/master.key"
gpgcmd="gpg --pinentry-mode=loopback --passphrase "$PASSPHRASE" "

$gpgcmd --batch --quick-add-key $KEYID ed25519 sign 0
$gpgcmd --batch --quick-add-key $KEYID cv25519 encr 0 # Per Yubikey Docs, ed25519 is not supported for Encryption/Decryption, only auth and signing. https://support.yubico.com/hc/en-us/articles/360016649139-YubiKey-5-2-Enhancements-to-OpenPGP-3-4-Support
$gpgcmd --batch --quick-add-key $KEYID ed25519 auth 0 

$gpgcmd --armor --export-secret-keys $KEYID > "$GNUPGHOME/mastersub.key"
$gpgcmd --armor --export-secret-subkeys $KEYID > "$GNUPGHOME/sub.key"

(cd ../ && COPYFILE_DISABLE=1 tar -cvvf - ./gnupg_home/ | gzip > "$KEYID-keyring.tar.gz") > /dev/null 2>&1
echo "Generated Master Keyring and backed up into $KEYID-keyring.tar.gz"
}

function keys_to_card {
  rm -fR gnupg_home_stubs
  cp -a gnupg_home gnupg_home_stubs
  cd gnupg_home_stubs
  export GNUPGHOME="$(pwd)"
  cleanup
  KEYID=$(gpg --list-options show-only-fpr-mbox --list-secret-keys 2>/dev/null | awk '{print $1;}')

  #Prompts to update YubiKey with user PIN, Admin PIN, and Reset Code
(
{
  echo admin
  sleep 2
  echo passwd
  sleep 2
  echo 1
  sleep 2
  echo 123456
  sleep 2
  echo ${KEYPIN}
  sleep 2
  echo ${KEYPIN}
  sleep 2

  echo 3
  sleep 2
  echo 12345678
  sleep 2
  echo ${ADMINPIN}
  sleep 2
  echo ${ADMINPIN}
  sleep 2

  echo 4
  sleep 2
  echo ${ADMINPIN}
  sleep 2
  echo ${RESETCODE}
  sleep 2
  echo ${RESETCODE}
  sleep 2

  echo Q

  sleep 2

  echo key-attr
  echo 2
  sleep 2
  echo 1
  sleep 2
  echo ${ADMINPIN}

  echo 2
  echo 1
  sleep 2
  echo ${ADMINPIN}
  sleep 2

  echo 2
  echo 1
  sleep 2
  echo ${ADMINPIN}
  sleep 2

  echo quit
}| gpg --command-fd=0 --status-fd=1 --pinentry-mode=loopback --card-edit

#Prompts to move local generated keys to YubiKey slots 1, 2, and 3
{
  echo toggle
  echo key 1
  echo keytocard
  echo 1
  sleep 2
  echo ${PASSPHRASE}
  sleep 2
  echo ${ADMINPIN}
  sleep 2
  echo key 1

  echo key 2
  echo keytocard
  echo 2
  sleep 2
  echo ${PASSPHRASE}
  #sleep 2
  #echo ${ADMINPIN}
  sleep 2
  echo key 2

  echo key 3
  echo keytocard
  echo 3
  sleep 2
  echo ${PASSPHRASE}
  #sleep 2
  #echo ${ADMINPIN}
  sleep 2
  echo key 3

  echo save
} | gpg --command-fd=0 --status-fd=1 --pinentry-mode=loopback --edit-key $KEYID
) >/dev/null 2>&1

gpgcmd="gpg --pinentry-mode=loopback --passphrase "$PASSPHRASE" "
$gpgcmd -a --export-secret-keys $KEYID > "$GNUPGHOME/masterstubs.txt"
$gpgcmd -a --export-secret-subkeys $KEYID > "$GNUPGHOME/subkeystubs.txt"
$gpgcmd -a --export $KEYID > "$GNUPGHOME/publickey.txt"

rm -f "$GNUPGHOME/private-keys-v1.d/*" > /dev/null 2>&1
(cd ../ && COPYFILE_DISABLE=1 tar -cvvf - ./gnupg_home_stubs/ | gzip > "$KEYID-keystubs.tar.gz") >/dev/null 2>&1

cd ../
$gpgcmd --armor --export $EMAIL > $KEYID-pubkey-master.asc

cleanup
SSH_AUTH_SOCK=''
sleep 5
eval "$(gpg-agent --daemon --enable-ssh-support)"

while [ ! -S $SSH_AUTH_SOCK ]
do
  sleep 1
done

sleep 5
ssh-add -L > $KEYID-ssh-pubkey
}

function keys_to_user {
  now=$(date +"%Y%m%d-%s")
  if [ -e "$HOME/.gnupg" ]; then
    mv "$HOME/.gnupg" "$HOME/.gnupg.$now"
  fi
  cp -r gnupg_home_stubs ~/.gnupg
  sudo chown -R "$(whoami)" ~/.gnupg
  sudo find ~/.gnupg -type f -exec chmod 600 {} \;
  sudo find ~/.gnupg -type d -exec chmod 700 {} \;
  setup_gpg_agent
  cleanup
}

case "${1:-}" in
  'init')
    echo "Installing dependencies, you may be asked for a password"
    install
    echo "You may need to reboot to have access to the key as your user"
    ;;
  'reset-yubikey')
    echo "Resetting your yubikey GPG app to factory defaults"
    reset_yubikey
    cleanup
    ;;
  'generate-master')
    echo "Generating Master Key and Directory"
    generate_master
    cleanup
    if [ "${GENERATE_MASTER_SKIPPED:-0}" -eq 0 ]; then
      echo "Your Public Key for sharing is in $KEYID-pubkey-master.asc"
    fi
    ;;
  'keys-to-card')
    echo "Copy Your Keys to your Yubikey"
    keys_to_card
    echo 'Complete! Run ./setup-yubikey keys-to-user to move the gnupg_home_stubs to ~/.gnupg/'
    cleanup
    ;;
  'keys-to-user')
    echo "Copy Your Keys to your home directory"
    keys_to_user
    echo 'Complete! Please reboot and return to README to complete setup'
    cleanup
    ;;
  'enable-hmac')
    enable_hmac
    ;;
  'setup-gpg-agent')
    setup_gpg_agent
    ;;
  'setup-gpg-helpers')
    setup_gpg_helpers
    ;;
  'init-ez')
    echo "Initialzing and generating user keys"
    init_ez
    ;;
  'setup-key-ez')
    echo "Reseting YubiKey and copying user keys there"
    setup_key_ez
    ;;
  'oneshot')
    echo "Running one-shot setup flow"
    oneshot
    ;;
  'setup-vars')
    setup_vars
    ;;
  'help'|'-h'|'--help')
    help
    ;;
  *)
    help
    exit 1
    ;;
esac
